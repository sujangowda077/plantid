# ── Supabase ──────────────────────────────────────────────────
# Get from: https://app.supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key-here

# ── PlantNet API  (SERVER-SIDE ONLY — no NEXT_PUBLIC_ prefix) ─
# Free key (500 req/day): https://my.plantnet.org/
PLANTNET_API_KEY=your-plantnet-api-key-here

# ── Plant.id API  (optional, more accurate) ────────────────────
# Paid plans: https://plant.id/
# Uncomment when ready:
# PLANTID_API_KEY=your-plantid-key-here
